# ---------------------------------------------------------------------------
# recon-platform configuration. Copy to `.env` and adjust.
# Every variable is optional; the platform runs offline with sane defaults.
# Prefix: RECON_  (nested keys use __, e.g. RECON_LLM__MODEL)
# ---------------------------------------------------------------------------

# --- LLM (Anthropic Claude via LangChain) ---------------------------------
# Without an API key the Planner falls back to a deterministic plan, so the
# whole pipeline still runs end-to-end offline.
ANTHROPIC_API_KEY=
RECON_LLM__MODEL=claude-sonnet-4-6
RECON_LLM__EFFORT=high
RECON_LLM__ENABLED=true

# --- Engagement / authorization ------------------------------------------
# Targets you are NOT authorized to test must never be entered here.
RECON_AUTHORIZED_ONLY=true

# --- Networking -----------------------------------------------------------
RECON_HTTP__TIMEOUT_SECONDS=15
RECON_HTTP__USER_AGENT=recon-platform/0.1 (authorized-security-testing)
RECON_HTTP__MAX_CONCURRENCY=10

# --- Persistence (optional; in-memory defaults used if unset) -------------
RECON_REDIS_URL=
RECON_DATABASE_URL=

# --- API / dashboard ------------------------------------------------------
RECON_API__HOST=127.0.0.1
RECON_API__PORT=8000

# --- Browser agent (Phase 2; opt-in) --------------------------------------
# Off by default. Requires the extra: pip install '.[browser]' && playwright
# install chromium. When disabled or Playwright is absent, the browser step
# degrades to a clean no-op. (CLI: --browser / `recon browse <target>`.)
RECON_BROWSER__ENABLED=false
RECON_BROWSER__HEADLESS=true
RECON_BROWSER__NAV_TIMEOUT_SECONDS=30
RECON_BROWSER__SCREENSHOT=true
RECON_BROWSER__SCREENSHOT_DIR=reports/screenshots

# --- Vision agent (Phase 3; opt-in) ---------------------------------------
# Off by default. Requires the extra: pip install '.[vision]'. Analyzes the
# browser's screenshots (enabling vision implies the browser). OCR provider is
# pluggable (easyocr | rapidocr | paddleocr); unknown/uninstalled engines fall
# back to a null provider. When no vision backend is installed, the step no-ops.
# (CLI: --vision / `recon vision <target>`.)
RECON_VISION__ENABLED=false
RECON_VISION__OCR_PROVIDER=easyocr
RECON_VISION__DETECTOR=heuristic
RECON_VISION__MIN_CONFIDENCE=0.4
RECON_VISION__ANNOTATE=true
RECON_VISION__ANNOTATE_DIR=reports/vision

# --- Desktop agent (Phase 4; opt-in) --------------------------------------
# Off by default. Requires the extra: pip install '.[desktop]'. Two-key safety:
# ENABLED turns on read-only observation (window discovery, screen capture,
# clipboard read); ALLOW_INPUT additionally permits real mouse/keyboard input —
# leave it false to record planned (dry-run) interactions only. When no desktop
# backend (or display) is present, the step degrades to a clean no-op.
# (CLI: --desktop / `recon desktop <target>`.)
RECON_DESKTOP__ENABLED=false
RECON_DESKTOP__ALLOW_INPUT=false
RECON_DESKTOP__BACKEND=pyautogui
RECON_DESKTOP__SCREENSHOT=true
RECON_DESKTOP__SCREENSHOT_DIR=reports/desktop
RECON_DESKTOP__MAX_WINDOWS=50
RECON_DESKTOP__MAX_ACTIONS=25

# --- Active recon / tool plugins (Phase 5; opt-in) ------------------------
# Off by default and INTRUSIVE. External binaries (httpx, subfinder, amass,
# naabu, nmap, katana, gau, dirsearch, ffuf, nuclei) are discovered on PATH and
# never imported, so any that are not installed are skipped cleanly. Two-key
# safety: ENABLED turns the agent on; AUTHORIZED is a separate, explicit
# acknowledgment that you are permitted to actively scan the target. Active tools
# run only when BOTH are true AND the target passes the authorization gate.
# (CLI: --active / `recon active-recon <target>`.)
RECON_ACTIVE_RECON__ENABLED=false
RECON_ACTIVE_RECON__AUTHORIZED=false
# Optional subset of tools to run (comma/JSON list); empty ⇒ all available.
RECON_ACTIVE_RECON__TOOLS=
RECON_ACTIVE_RECON__TIMEOUT_SECONDS=120
RECON_ACTIVE_RECON__RETRIES=0
RECON_ACTIVE_RECON__MAX_OUTPUT_BYTES=1000000
# Wordlist for ffuf / dirsearch; when empty those tools skip rather than guess.
RECON_ACTIVE_RECON__WORDLIST=
# Optional nuclei severity filter, e.g. low,medium,high,critical.
RECON_ACTIVE_RECON__NUCLEI_SEVERITY=
# Optional shared rate limit (req/s) for tools that accept one (0 ⇒ unset).
RECON_ACTIVE_RECON__RATE_LIMIT=0

# --- Logging --------------------------------------------------------------
RECON_LOG_LEVEL=INFO
RECON_LOG_JSON=false
