# ---------------------------------------------------------------------------
# recon-platform configuration. Copy to `.env` and adjust.
# Every variable is optional; the platform runs offline with sane defaults.
# Prefix: RECON_  (nested keys use __, e.g. RECON_LLM__MODEL)
# ---------------------------------------------------------------------------

# --- LLM (Anthropic Claude via LangChain) ---------------------------------
# Without an API key the Planner falls back to a deterministic plan, so the
# whole pipeline still runs end-to-end offline.
ANTHROPIC_API_KEY=
RECON_LLM__MODEL=claude-sonnet-4-6
RECON_LLM__EFFORT=high
RECON_LLM__ENABLED=true

# --- Engagement / authorization ------------------------------------------
# Targets you are NOT authorized to test must never be entered here.
RECON_AUTHORIZED_ONLY=true

# --- Networking -----------------------------------------------------------
RECON_HTTP__TIMEOUT_SECONDS=15
RECON_HTTP__USER_AGENT=recon-platform/0.1 (authorized-security-testing)
RECON_HTTP__MAX_CONCURRENCY=10

# --- Persistence (optional; in-memory defaults used if unset) -------------
RECON_REDIS_URL=
RECON_DATABASE_URL=

# --- API / dashboard ------------------------------------------------------
RECON_API__HOST=127.0.0.1
RECON_API__PORT=8000

# --- Browser agent (Phase 2; opt-in) --------------------------------------
# Off by default. Requires the extra: pip install '.[browser]' && playwright
# install chromium. When disabled or Playwright is absent, the browser step
# degrades to a clean no-op. (CLI: --browser / `recon browse <target>`.)
RECON_BROWSER__ENABLED=false
RECON_BROWSER__HEADLESS=true
RECON_BROWSER__NAV_TIMEOUT_SECONDS=30
RECON_BROWSER__SCREENSHOT=true
RECON_BROWSER__SCREENSHOT_DIR=reports/screenshots

# --- Logging --------------------------------------------------------------
RECON_LOG_LEVEL=INFO
RECON_LOG_JSON=false
